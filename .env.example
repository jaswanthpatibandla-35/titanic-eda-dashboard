# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development       # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=changeme-use-a-long-random-string-in-production
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600    # 1 hour
CACHE_MAX_SIZE=128
